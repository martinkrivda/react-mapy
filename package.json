{
  "name": "react-mapy",
  "version": "0.2.0",
  "description": "TypeScript React map primitives and presets powered by Leaflet, with Mapy.com as the default tile provider.",
  "license": "MIT",
  "author": "Martin Křivda",
  "type": "module",
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "private": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/martinkrivda/react-mapy"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js",
      "require": "./dist/core.cjs"
    },
    "./leaflet": {
      "types": "./dist/leaflet.d.ts",
      "import": "./dist/leaflet.js",
      "require": "./dist/leaflet.cjs"
    },
    "./parsers": {
      "types": "./dist/parsers.d.ts",
      "import": "./dist/parsers.js",
      "require": "./dist/parsers.cjs"
    },
    "./presets": {
      "types": "./dist/presets.d.ts",
      "import": "./dist/presets.js",
      "require": "./dist/presets.cjs"
    },
    "./providers/mapy": {
      "types": "./dist/providers/mapy.d.ts",
      "import": "./dist/providers/mapy.js",
      "require": "./dist/providers/mapy.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22.20.0 <25",
    "pnpm": ">=10.33.0 <11"
  },
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "eslint": "^10.0.0"
      }
    }
  },
  "keywords": [
    "react",
    "react-library",
    "typescript",
    "leaflet",
    "mapy",
    "mapy.com",
    "maps",
    "gpx",
    "geojson"
  ],
  "scripts": {
    "build": "tsup",
    "build-storybook": "HOME=$PWD/.storybook-home STORYBOOK_DISABLE_TELEMETRY=1 CI=1 storybook build",
    "changeset": "changeset",
    "clean": "rimraf coverage dist storybook-static playground/dist",
    "dev": "vite",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "lint": "eslint .",
    "postbuild": "pnpm verify:dist-assets",
    "prepack": "pnpm build",
    "release": "changeset publish",
    "storybook": "HOME=$PWD/.storybook-home STORYBOOK_DISABLE_TELEMETRY=1 storybook dev -p 6006",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "verify:dist-assets": "node scripts/assert-dist-marker-assets.mjs",
    "version-packages": "changeset version",
    "prepare": "husky"
  },
  "peerDependencies": {
    "leaflet": "^1.9.4",
    "leaflet.markercluster": "^1.5.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "peerDependenciesMeta": {
    "leaflet.markercluster": {
      "optional": true
    }
  },
  "dependencies": {
    "fast-xml-parser": "^5.5.11",
    "simpleheat": "^0.4.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@eslint/js": "^10.0.1",
    "@storybook/addon-docs": "10.3.6",
    "@storybook/react-vite": "10.3.6",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/geojson": "^7946.0.16",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "leaflet": "^1.9.4",
    "leaflet.markercluster": "^1.5.3",
    "prettier": "^3.8.2",
    "rimraf": "^6.1.3",
    "storybook": "10.3.6",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "vite": "^8.0.8",
    "vitest": "^4.1.4",
    "eslint-plugin-storybook": "10.3.5"
  }
}
